# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# GitHub personal access token (classic PAT)
# Required scopes: read:org, repo (read), security_events (for vulnerability alerts)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_YOUR_TOKEN_HERE

# Optional: default org to audit (can also pass as CLI arg)
# GITHUB_ORG=govex
